                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Trimmed = Table.TransformColumns(PromotedHeaders, List.Transform(Table.Columns(PromotedHeaders), (c) => {c, each if _ is text then Text.Trim(_) else _, type any})),",
                "    StandardizedYesNo = Table.TransformColumns(Trimmed, {{\"Passed\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}}, null, MissingField.Ignore),",
                "    Typed = Table.TransformColumnTypes(StandardizedYesNo, {{\"TranscriptCourseID\", type text}, {\"LocalStudentID\", type text}, {\"CourseCode\", type text}, {\"CourseName\", type text}, {\"SubjectArea\", type text}, {\"SchoolYear\", Int64.Type}, {\"Term\", type text}, {\"CreditsEarned\", type number}, {\"FinalGrade\", type text}, {\"Passed\", type logical}}, \"en-US\"),",
                "    WithSourceFile = Table.AddColumn(Typed, \"SourceFileName\", each \"synthetic_transcripts.csv\", type text),",
                "    WithRefreshTimestamp = Table.AddColumn(WithSourceFile, \"RefreshTimestamp\", each DateTimeZone.UtcNow(), type datetimezone)",
