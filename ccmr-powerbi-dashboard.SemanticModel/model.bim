          }
        ],
        "partitions": [
          {
            "name": "FactAssessmentAttempt",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(pDataFolder & \"synthetic_assessments.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Trimmed = Table.TransformColumns(PromotedHeaders, List.Transform(Table.Columns(PromotedHeaders), (c) => {c, each if _ is text then Text.Trim(_) else _, type any})),",
                "    StandardizedYesNo = Table.TransformColumns(Trimmed, {{\"MetCriterion\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"AccommodationUsed\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}}, null, MissingField.Ignore),",
                "    Typed = Table.TransformColumnTypes(StandardizedYesNo, {{\"AssessmentAttemptID\", type text}, {\"LocalStudentID\", type text}, {\"AssessmentType\", type text}, {\"Subject\", type text}, {\"AssessmentDate\", type date}, {\"ScaleScore\", Int64.Type}, {\"MetCriterion\", type logical}, {\"AccommodationUsed\", type logical}, {\"Administration\", type text}}, \"en-US\"),",
                "    WithSourceFile = Table.AddColumn(Typed, \"SourceFileName\", each \"synthetic_assessments.csv\", type text),",
                "    WithRefreshTimestamp = Table.AddColumn(WithSourceFile, \"RefreshTimestamp\", each DateTimeZone.UtcNow(), type datetimezone)",
                "in",
                "    WithRefreshTimestamp"
              ]
            }
          }
        ]
      },
