                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Trimmed = Table.TransformColumns(PromotedHeaders, List.Transform(Table.Columns(PromotedHeaders), (c) => {c, each if _ is text then Text.Trim(_) else _, type any})),",
                "    Typed = Table.TransformColumnTypes(Trimmed, {{\"SkillRecordID\", type text}, {\"LocalStudentID\", type text}, {\"ContentArea\", type text}, {\"SkillName\", type text}, {\"EvidenceSource\", type text}, {\"PercentMastery\", Int64.Type}, {\"SkillStatus\", type text}, {\"RecommendedGroup\", type text}}, \"en-US\"),",
                "    WithSourceFile = Table.AddColumn(Typed, \"SourceFileName\", each \"synthetic_assessment_skill_detail.csv\", type text),",
                "    WithRefreshTimestamp = Table.AddColumn(WithSourceFile, \"RefreshTimestamp\", each DateTimeZone.UtcNow(), type datetimezone)",
