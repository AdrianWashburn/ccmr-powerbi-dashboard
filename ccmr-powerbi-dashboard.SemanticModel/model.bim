      {
        "name": "DimDate",
        "dataCategory": "Time",
        "columns": [
          {
            "name": "Date",
            "dataType": "dateTime",
            "sourceColumn": "Date"
          }
        ],
        "partitions": [
          {
            "name": "DimDate",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "CALENDAR ( DATE ( 2023, 7, 1 ), DATE ( 2028, 8, 31 ) )"
            }
          }
        ]
      },
      {
        "name": "DimAssessment",
        "columns": [],
        "partitions": [
          {
            "name": "DimAssessment",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "SUMMARIZE ( FactAssessmentAttempt, FactAssessmentAttempt[AssessmentType], FactAssessmentAttempt[Subject] )"
            }
          }
        ]
      },
      {
        "name": "DimCourse",
        "columns": [],
        "partitions": [
          {
            "name": "DimCourse",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "DISTINCT ( UNION ( SELECTCOLUMNS ( FactTranscriptCourse, \"CourseCode\", FactTranscriptCourse[CourseCode], \"CourseName\", FactTranscriptCourse[CourseName], \"SubjectArea\", FactTranscriptCourse[SubjectArea] ), SELECTCOLUMNS ( FactCurrentSchedule, \"CourseCode\", FactCurrentSchedule[CourseCode], \"CourseName\", FactCurrentSchedule[CourseName], \"SubjectArea\", FactCurrentSchedule[SubjectArea] ), SELECTCOLUMNS ( FactCourseRequest, \"CourseCode\", FactCourseRequest[CourseCode], \"CourseName\", FactCourseRequest[CourseName], \"SubjectArea\", FactCourseRequest[SubjectArea] ) ) )"
            }
          }
        ]
      },
      {
        "name": "DimCampus",
        "columns": [],
        "partitions": [
          {
            "name": "DimCampus",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "SUMMARIZE ( DimStudent, DimStudent[CampusID], DimStudent[CampusName] )"
            }
          }
        ]
      },
      {
        "name": "DimCounselor",
        "columns": [],
        "partitions": [
          {
            "name": "DimCounselor",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "DISTINCT ( SELECTCOLUMNS ( DimStudent, \"CounselorName\", DimStudent[CounselorName] ) )"
            }
          }
        ]
      },
      {
        "name": "DimPathway",
        "columns": [],
        "partitions": [
          {
            "name": "DimPathway",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "DATATABLE ( \"Pathway\", STRING, \"PathwayCategory\", STRING, { { \"SAT\", \"College Assessment\" }, { \"ACT\", \"College Assessment\" }, { \"TSIA2\", \"TSIA\" }, { \"AP\", \"Advanced Academics\" }, { \"IB\", \"Advanced Academics\" }, { \"Dual Credit\", \"College Coursework\" }, { \"OnRamps\", \"College Coursework\" }, { \"CTE + IBC\", \"Career\" }, { \"Military\", \"Military\" }, { \"SPED Alternative\", \"Special Programs\" } } )"
            }
          }
        ]
      },
      {
        "name": "FactCCMRStatus",
        "columns": [],
        "partitions": [
          {
            "name": "FactCCMRStatus",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "SELECTCOLUMNS ( FILTER ( FactAssessmentAttempt, FactAssessmentAttempt[MetCriterion] = TRUE() ), \"LocalStudentID\", FactAssessmentAttempt[LocalStudentID], \"Pathway\", FactAssessmentAttempt[AssessmentType], \"EvidenceVerified\", TRUE(), \"RecommendationBucket\", \"Already CCMR-met\" )"
            }
          }
        ]
      },
      {
        "name": "_Measures",
        "columns": [
          {
            "name": "MeasureTable",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "MeasureTable"
          }
        ],
        "partitions": [
          {
            "name": "_Measures",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "DATATABLE ( \"MeasureTable\", STRING, { { \"Measures\" } } )"
            }
          }
        ],
        "measures": [
          {
            "name": "Total Students",
            "expression": "DISTINCTCOUNT ( DimStudent[LocalStudentID] )",
            "formatString": "#,0"
          },
          {
            "name": "Active Students",
            "expression": "CALCULATE ( [Total Students], DimStudent[EnrollmentStatus] = \"Active\" )",
            "formatString": "#,0"
          },
          {
            "name": "Seniors",
            "expression": "CALCULATE ( [Total Students], DimStudent[GradeLevel] = 12 )",
            "formatString": "#,0"
          },
          {
            "name": "Juniors",
            "expression": "CALCULATE ( [Total Students], DimStudent[GradeLevel] = 11 )",
            "formatString": "#,0"
          },
          {
            "name": "Sophomores",
            "expression": "CALCULATE ( [Total Students], DimStudent[GradeLevel] = 10 )",
            "formatString": "#,0"
          },
          {
            "name": "Freshmen",
            "expression": "CALCULATE ( [Total Students], DimStudent[GradeLevel] = 9 )",
            "formatString": "#,0"
          },
          {
            "name": "CCMR Met Count",
            "expression": "DISTINCTCOUNT ( FactCCMRStatus[LocalStudentID] )",
            "formatString": "#,0"
          },
          {
            "name": "CCMR Not Met Count",
            "expression": "[Total Students] - [CCMR Met Count]",
            "formatString": "#,0"
          },
          {
            "name": "CCMR Met %",
            "expression": "DIVIDE ( [CCMR Met Count], [Total Students] )",
            "formatString": "0.00%;-0.00%;0.00%"
          },
          {
            "name": "Notes Count",
            "expression": "COUNTROWS ( FactCounselorNote )",
            "formatString": "#,0"
          },
          {
            "name": "Open Actions Count",
            "expression": "CALCULATE ( COUNTROWS ( FactCounselorNote ), FactCounselorNote[ActionStatus] = \"Open\" )",
            "formatString": "#,0"
          },
          {
            "name": "Overdue Actions Count",
            "expression": "CALCULATE ( COUNTROWS ( FactCounselorNote ), FactCounselorNote[ActionStatus] = \"Open\", FactCounselorNote[FollowUpDate] < TODAY() )",
            "formatString": "#,0"
          },
          {
            "name": "Students Assigned Intervention",
            "expression": "DISTINCTCOUNT ( FactInterventionAssignment[LocalStudentID] )",
            "formatString": "#,0"
          },
          {
            "name": "Retest Ready Count",
            "expression": "CALCULATE ( DISTINCTCOUNT ( FactInterventionAssignment[LocalStudentID] ), FactInterventionAssignment[RetestRecommended] = TRUE() )",
            "formatString": "#,0"
          },
          {
            "name": "CTE Students Count",
            "expression": "DISTINCTCOUNT ( FactCTEProgress[LocalStudentID] )",
            "formatString": "#,0"
          },
          {
            "name": "Completer Count",
            "expression": "CALCULATE ( DISTINCTCOUNT ( FactCTEProgress[LocalStudentID] ), FactCTEProgress[Completer] = TRUE() )",
            "formatString": "#,0"
          },
          {
            "name": "IBC Passed Count",
            "expression": "CALCULATE ( DISTINCTCOUNT ( FactIBC[LocalStudentID] ), FactIBC[Passed] = TRUE() )",
            "formatString": "#,0"
          },
          {
            "name": "IBC Verified Count",
            "expression": "CALCULATE ( DISTINCTCOUNT ( FactIBC[LocalStudentID] ), FactIBC[Verified] = TRUE() )",
            "formatString": "#,0"
          },
          {
            "name": "Data Quality Score",
            "expression": "1 - DIVIDE ( [Missing LocalStudentID Count], [Total Students] )",
            "formatString": "0.00%;-0.00%;0.00%"
          },
          {
            "name": "Missing LocalStudentID Count",
            "expression": "COUNTROWS ( FILTER ( DimStudent, ISBLANK ( DimStudent[LocalStudentID] ) ) )",
            "formatString": "#,0"
          }
        ]
      },
      {
        "name": "Security",
        "columns": [],
        "partitions": [
          {
            "name": "Security",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "DATATABLE ( \"UserEmail\", STRING, \"Role\", STRING, \"CampusID\", STRING, \"CounselorName\", STRING, \"TeacherID\", STRING, \"ProgramAccess\", STRING, \"CanViewNotes\", BOOLEAN, \"CanViewSensitiveFlags\", BOOLEAN, { { \"district.leader@example.org\", \"District\", \"001\", \"\", \"\", \"All\", TRUE, TRUE }, { \"counselor.nguyen@example.org\", \"Counselor\", \"001\", \"A. Nguyen\", \"\", \"All\", TRUE, TRUE } } )"
            }
          }
        ]
      }
