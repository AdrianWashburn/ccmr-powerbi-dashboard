{
  "name": "CCMR Pathway Navigator",
  "compatibilityLevel": 1567,
  "model": {
    "culture": "en-US",
    "dataSources": [
      {
        "type": "structured",
        "name": "Sample CSV Folder",
        "connectionDetails": {
          "protocol": "file",
          "address": {
            "path": "sample_data"
          }
        },
        "credential": {
          "AuthenticationKind": "Anonymous"
        }
      }
    ],
    "expressions": [
      {
        "name": "pDataFolder",
        "kind": "m",
        "expression": "\"../sample_data/\"",
        "annotations": [
          {
            "name": "PBI_ParameterType",
            "value": "Text"
          },
          {
            "name": "PBI_ParameterDefaultValue",
            "value": "../sample_data/"
          }
        ]
      }
    ],
    "tables": [
      {
        "name": "DimStudent",
        "columns": [
          {
            "name": "LocalStudentID",
            "dataType": "string",
            "sourceColumn": "LocalStudentID"
          },
          {
            "name": "TXUniqueStudentID",
            "dataType": "string",
            "sourceColumn": "TXUniqueStudentID"
          },
          {
            "name": "FirstName",
            "dataType": "string",
            "sourceColumn": "FirstName"
          },
          {
            "name": "LastName",
            "dataType": "string",
            "sourceColumn": "LastName"
          },
          {
            "name": "CampusName",
            "dataType": "string",
            "sourceColumn": "CampusName"
          },
          {
            "name": "CampusID",
            "dataType": "string",
            "sourceColumn": "CampusID"
          },
          {
            "name": "GradeLevel",
            "dataType": "int64",
            "sourceColumn": "GradeLevel"
          },
          {
            "name": "CohortYear",
            "dataType": "int64",
            "sourceColumn": "CohortYear"
          },
          {
            "name": "DateOfBirth",
            "dataType": "dateTime",
            "sourceColumn": "DateOfBirth"
          },
          {
            "name": "CounselorName",
            "dataType": "string",
            "sourceColumn": "CounselorName"
          },
          {
            "name": "EnrollmentStatus",
            "dataType": "string",
            "sourceColumn": "EnrollmentStatus"
          },
          {
            "name": "TeacherID",
            "dataType": "string",
            "sourceColumn": "TeacherID"
          },
          {
            "name": "SourceFileName",
            "dataType": "string",
            "sourceColumn": "SourceFileName"
          },
          {
            "name": "RefreshTimestamp",
            "dataType": "dateTime",
            "sourceColumn": "RefreshTimestamp"
          }
        ],
        "partitions": [
          {
            "name": "DimStudent",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(pDataFolder & \"synthetic_students.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Trimmed = Table.TransformColumns(PromotedHeaders, List.Transform(Table.Columns(PromotedHeaders), (c) => {c, each if _ is text then Text.Trim(_) else _, type any})),",
                "    Typed = Table.TransformColumnTypes(Trimmed, {{\"LocalStudentID\", type text}, {\"TXUniqueStudentID\", type text}, {\"FirstName\", type text}, {\"LastName\", type text}, {\"CampusName\", type text}, {\"CampusID\", type text}, {\"GradeLevel\", Int64.Type}, {\"CohortYear\", Int64.Type}, {\"DateOfBirth\", type date}, {\"CounselorName\", type text}, {\"EnrollmentStatus\", type text}, {\"TeacherID\", type text}}, \"en-US\"),",
                "    WithSourceFile = Table.AddColumn(Typed, \"SourceFileName\", each \"synthetic_students.csv\", type text),",
                "    WithRefreshTimestamp = Table.AddColumn(WithSourceFile, \"RefreshTimestamp\", each DateTimeZone.UtcNow(), type datetimezone)",
                "in",
                "    WithRefreshTimestamp"
              ]
            }
          }
        ]
      },
      {
        "name": "DimStudentDemographics",
        "columns": [
          {
            "name": "LocalStudentID",
            "dataType": "string",
            "sourceColumn": "LocalStudentID"
          },
          {
            "name": "RaceEthnicity",
            "dataType": "string",
            "sourceColumn": "RaceEthnicity"
          },
          {
            "name": "Gender",
            "dataType": "string",
            "sourceColumn": "Gender"
          },
          {
            "name": "EconomicallyDisadvantaged",
            "dataType": "boolean",
            "sourceColumn": "EconomicallyDisadvantaged"
          },
          {
            "name": "EmergentBilingual",
            "dataType": "boolean",
            "sourceColumn": "EmergentBilingual"
          },
          {
            "name": "Section504",
            "dataType": "boolean",
            "sourceColumn": "Section504"
          },
          {
            "name": "SpecialEdCurrent",
            "dataType": "boolean",
            "sourceColumn": "SpecialEdCurrent"
          },
          {
            "name": "SpecialEdFormer",
            "dataType": "boolean",
            "sourceColumn": "SpecialEdFormer"
          },
          {
            "name": "HighFocus",
            "dataType": "boolean",
            "sourceColumn": "HighFocus"
          },
          {
            "name": "HighlyMobile",
            "dataType": "boolean",
            "sourceColumn": "HighlyMobile"
          },
          {
            "name": "FosterCare",
            "dataType": "boolean",
            "sourceColumn": "FosterCare"
          },
          {
            "name": "Homeless",
            "dataType": "boolean",
            "sourceColumn": "Homeless"
          },
          {
            "name": "Migratory",
            "dataType": "boolean",
            "sourceColumn": "Migratory"
          },
          {
            "name": "ContinuouslyEnrolled",
            "dataType": "boolean",
            "sourceColumn": "ContinuouslyEnrolled"
          },
          {
            "name": "SourceFileName",
            "dataType": "string",
            "sourceColumn": "SourceFileName"
          },
          {
            "name": "RefreshTimestamp",
            "dataType": "dateTime",
            "sourceColumn": "RefreshTimestamp"
          }
        ],
        "partitions": [
          {
            "name": "DimStudentDemographics",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(pDataFolder & \"synthetic_demographics.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Trimmed = Table.TransformColumns(PromotedHeaders, List.Transform(Table.Columns(PromotedHeaders), (c) => {c, each if _ is text then Text.Trim(_) else _, type any})),",
                "    StandardizedYesNo = Table.TransformColumns(Trimmed, {{\"EconomicallyDisadvantaged\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"EmergentBilingual\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"Section504\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"SpecialEdCurrent\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"SpecialEdFormer\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"HighFocus\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"HighlyMobile\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"FosterCare\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"Homeless\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"Migratory\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}, {\"ContinuouslyEnrolled\", each if _ = true or Text.Upper(Text.From(_)) = \"YES\" or Text.Upper(Text.From(_)) = \"TRUE\" or Text.From(_) = \"1\" then true else if _ = false or Text.Upper(Text.From(_)) = \"NO\" or Text.Upper(Text.From(_)) = \"FALSE\" or Text.From(_) = \"0\" then false else null, type logical}}, null, MissingField.Ignore),",
                "    Typed = Table.TransformColumnTypes(StandardizedYesNo, {{\"LocalStudentID\", type text}, {\"RaceEthnicity\", type text}, {\"Gender\", type text}, {\"EconomicallyDisadvantaged\", type logical}, {\"EmergentBilingual\", type logical}, {\"Section504\", type logical}, {\"SpecialEdCurrent\", type logical}, {\"SpecialEdFormer\", type logical}, {\"HighFocus\", type logical}, {\"HighlyMobile\", type logical}, {\"FosterCare\", type logical}, {\"Homeless\", type logical}, {\"Migratory\", type logical}, {\"ContinuouslyEnrolled\", type logical}}, \"en-US\"),",
                "    WithSourceFile = Table.AddColumn(Typed, \"SourceFileName\", each \"synthetic_demographics.csv\", type text),",
                "    WithRefreshTimestamp = Table.AddColumn(WithSourceFile, \"RefreshTimestamp\", each DateTimeZone.UtcNow(), type datetimezone)",
                "in",
                "    WithRefreshTimestamp"
              ]
            }
          }
        ]
      },
      {
