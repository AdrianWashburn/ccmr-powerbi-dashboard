                "    Typed = Table.TransformColumnTypes(WithInterventionKey, {{\"ContentArea\", type text}, {\"SkillName\", type text}, {\"EvidenceSource\", type text}, {\"RecommendedIntervention\", type text}, {\"ProgressMonitor\", type text}, {\"ExitCriterion\", type text}, {\"RetestRecommendation\", type text}, {\"SuggestedInterventionGroup\", type text}, {\"InterventionKey\", type text}}, \"en-US\"),",
                "    WithSourceFile = Table.AddColumn(Typed, \"SourceFileName\", each \"synthetic_intervention_map.csv\", type text),",
                "    WithRefreshTimestamp = Table.AddColumn(WithSourceFile, \"RefreshTimestamp\", each DateTimeZone.UtcNow(), type datetimezone)",
                "in",
                "    WithRefreshTimestamp"
              ]
            }
          }
        ]
      },
